version: '3.8'

services:
  # Base de Datos para las 3 etapas de datos (Raw, Processed, Ready)
  postgres:
    image: postgres:15
    container_name: postgres_db
    restart: always
    environment:
    # Archivo .env
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    ports:
      - "${POSTGRES_PORT}:5432"
    volumes:
      # Postgres DB: Named Volumes, Script: Bind Mount
      # El Named Volumes permite desacoplar nuestra arquitectura del sistema de archivos del host
      # A medida que la DB crezca, el volumen usa el disco de la VM y no del host
      # Hace un montaje a nivel kernel de postgres_data
      - postgres_data:/var/lib/postgresql/data
      # Usamos Bind Mount para los scripts ya que estos pueden cambiar con frecuencia y nos interesa que los cambios se vean reflejados
      # Define como serán los datos, pero no son los datos. Si se borra el archivo no importa porque la DB ya funciona,
      - ./data_management/init_db:/docker-entrypoint-initdb.d # Script de tablas

  # Storage de Objetos para Modelos (S3 compatible)
  minio:
    image: quay.io/minio/minio
    container_name: minio_server
    ports:
      - "9000:9000" # API
      - "9001:9001" # Consola Web
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    volumes:
      - minio_data:/data
    command: server /data --console-address ":9001"

  airflow:
    build: ./airflow
    container_name: airflow_orchestrator
    depends_on:
      - postgres
    environment:
    # --- CONFIGURACIÓN DE CONEXIÓN A METADATOS ---
      # Protocolo: postgresql+psycopg2
      # Credenciales: Extraídas de variables de entorno (.env) para seguridad
      # Host: 'postgres' (nombre del servicio en la red de Docker)
      # Puerto: 5432 (puerto interno del contenedor de DB)  
      - AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      # LocalExecutor: Permite la ejecución de tareas en paralelo dentro del mismo contenedor
      - AIRFLOW__CORE__EXECUTOR=LocalExecutor
      # Desactiva los DAGs de ejemplo predeterminados
      - AIRFLOW__CORE__LOAD_EXAMPLES=False
      # Config
      - _AIRFLOW_WWW_USER_USERNAME=${AIRFLOW_ADMIN_USER}
      - _AIRFLOW_WWW_USER_PASSWORD=${AIRFLOW_ADMIN_PASSWORD}
    volumes:
      - ./airflow/logs:/opt/airflow/logs
      - ./airflow/dags:/opt/airflow/dags
    ports:
      - "8001:8080"
    command: standalone



volumes:
  postgres_data:
  minio_data: